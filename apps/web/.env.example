# Browser-shell environment template.
# Never place API keys, OAuth secrets, database paths, or token settings here.
# Server-side local configuration belongs in the repo-root .env file.

APP_ENV=development
# Browser-only hint. The static app can also store this from:
# ?localApiOrigin=http://127.0.0.1:8000
LOCAL_API_ORIGIN=http://127.0.0.1:8000
